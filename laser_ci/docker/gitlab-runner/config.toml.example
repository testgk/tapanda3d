concurrent = 5
check_interval = 0
connection_max_age = "15m0s"
shutdown_timeout = 0

[session_server]
  session_timeout = 1800

[[runners]]
  name = "docker-runner"
  url = "https://gitlab.com"
  id = 51386593
  token = "glrt-dWEGgsrm4QHZvEz548-dZ2M6MQpvOjEKcDoxYWN5czkKdDozCnU6aGQzajIc.01.1o0kw2oe2"
  executor = "docker"
  tags = ["linux", "docker", "amd64"]
  run_untagged = false
  protected = false
  tls-skip-verify = true
  environment = ["JENKINS_API_TOKEN=your-password-here", "GITLAB_ACCESS_TOKEN=glpat-your-token-here"]
  [runners.docker]
    image = "ubuntu:22.04"
    privileged = true
    disable_entrypoint_overwrite = false
    oom_kill_disable = false
    disable_cache = false
    volumes = ["/cache", "/certs/client", "/var/run/docker.sock:/var/run/docker.sock"]
    pull_policy = ["if-not-present"]
    allowed_pull_policies = ["always", "if-not-present"]
    network_mode = "ci"
    environment = ["DOCKER_TLS_CERTDIR=", "GIT_SSL_NO_VERIFY=true"]
    shm_size = 0
  [runners.cache]
    MaxUploadedArchiveSize = 0
    [runners.cache.s3]
    [runners.cache.gcs]
    [runners.cache.azure]
