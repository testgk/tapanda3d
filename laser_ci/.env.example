# Copy this file to .env and fill in values for your environment.
# On machines behind a corporate proxy, set these:
# HTTP_PROXY=http://user@domain:password@proxy-host:port
# HTTPS_PROXY=http://user@domain:password@proxy-host:port
# NO_PROXY=localhost,127.0.0.1

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1