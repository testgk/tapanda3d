# Copy this file to jenkins.config.env and fill in your values.
# jenkins.config.env is gitignored — never commit it.

# --- Credentials ---
# Set both to the same value — Jenkins accepts the admin password for API calls.
JENKINS_ADMIN_PASSWORD=admin
JENKINS_API_TOKEN=admin

# --- Network ---
# IP the Jenkins ports are bound to on the host (0.0.0.0 = all interfaces)
JENKINS_BIND_IP=0.0.0.0
# Port exposed on the host for the Jenkins web UI
JENKINS_PORT=8080
# Port exposed on the host for Jenkins agent connections
JENKINS_AGENT_PORT=50000
# Publicly reachable URL for Jenkins — used by GitLab pipelines to trigger jobs.
# Set this to your domain or ngrok URL (e.g. http://jenkins.laser.ci).
JENKINS_PUBLIC_URL=http://localhost:8080

# --- GitLab ---
GITLAB_ACCESS_TOKEN=glpat-aP1WEyfZpPF3C-LzrZ1HwmM6MQpvOjEKdTpoZDNqMg8.01.170bqdp5b
GITLAB_PROJECT_URL=https://gitlab.com/aqualaser/laser_ci
